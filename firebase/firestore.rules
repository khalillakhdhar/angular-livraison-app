rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Function to check user role
    function hasRole(role) {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }
    
    // Function to check if user is admin
    function isAdmin() {
      return hasRole('admin');
    }
    
    // Function to check if user is driver
    function isDriver() {
      return hasRole('livreur');
    }
    
    // Function to check if user is client
    function isClient() {
      return hasRole('client');
    }
    
    // Function to check if user owns the resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users collection
    match /users/{userId} {
      // Admin can read/write all users
      allow read, write: if isAdmin();
      
      // Users can read/write their own profile
      allow read, write: if isOwner(userId);
      
      // Drivers can read other users for delivery purposes (limited fields)
      allow read: if isDriver() && isAuthenticated();
    }

    // Orders/Commandes collection
    match /commandes/{commandeId} {
      // Admin has full access
      allow read, write: if isAdmin();
      
      // Drivers can read orders assigned to them and update status
      allow read: if isDriver() && 
                     (resource.data.livreurId == request.auth.uid || 
                      resource.data.etatLivraison == 'nouvelle');
      allow update: if isDriver() && 
                       resource.data.livreurId == request.auth.uid &&
                       // Only allow updating specific fields
                       request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['etatLivraison', 'updatedAt', 'demarrageAt', 'livraisonAt']);
      
      // Clients can create orders and read/update their own orders
      allow create: if isClient() && request.resource.data.clientId == request.auth.uid;
      allow read, update: if isClient() && resource.data.clientId == request.auth.uid;
    }

    // Sorties collection
    match /sorties/{sortieId} {
      // Admin has full access
      allow read, write: if isAdmin();
      
      // Drivers can read their assigned sorties and update status
      allow read: if isDriver() && resource.data.livreurId == request.auth.uid;
      allow update: if isDriver() && 
                       resource.data.livreurId == request.auth.uid &&
                       // Only allow updating specific fields
                       request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['statut', 'heureDebut', 'heureFin', 'updatedAt', 'notes']);
    }

    // Logs collection (for audit trail)
    match /logs/{logId} {
      // Admin can read all logs
      allow read: if isAdmin();
      
      // All authenticated users can create logs
      allow create: if isAuthenticated();
    }

    // Statistics collection (read-only aggregated data)
    match /statistics/{statId} {
      // Admin can read all statistics
      allow read: if isAdmin();
      
      // Drivers can read their own performance stats
      allow read: if isDriver() && resource.data.livreurId == request.auth.uid;
    }

    // Configuration collection (app settings)
    match /config/{configId} {
      // Only admin can read/write configuration
      allow read, write: if isAdmin();
    }

    // Default deny rule for any other documents
    match /{document=**} {
      allow read, write: if false;
    }
  }
}